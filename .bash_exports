# .bash_exports

# Use colors
export CLICOLOR=1
export LSCOLORS=ExFxCxDxBxegedabagacad

# Set default editor
export EDITOR=vi

# Disable bash+less history
export HISTFILESIZE=0
export LESSHISTSIZE=0

# Export ansible vault password file
[ -f ${HOME}/.ansible_vault ] && export ANSIBLE_VAULT_PASSWORD_FILE="${HOME}/.ansible_vault"

# Prepend homebrew manpath, if applicable.
BREW_MANPATH=/usr/local/share/man
if [ -d "${BREW_MANPATH}" ]
then
  if [ ! -z "${MANPATH}" ]
  then
    export MANPATH="${BREW_MANPATH}:${MANPATH}"
  else
    export MANPATH="${BREW_MANPATH}"
  fi
fi

# Prepend homebrew binary paths, if applicable.
BREW_PACKAGES=/usr/local/opt
if [ -d "${BREW_PACKAGES}" ]
then
  for PACKAGE in ${BREW_PACKAGES}/*
  do
    [ -d "${PACKAGE}/libexec/bin" ] && export PATH="${PACKAGE}/libexec/bin:${PATH}"
    [ -d "${PACKAGE}/libexec/gnubin" ] && export PATH="${PACKAGE}/libexec/gnubin:${PATH}"
  done
fi
