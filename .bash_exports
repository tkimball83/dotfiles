# .bash_exports

# Use colors
export CLICOLOR=1
export LSCOLORS=ExFxCxDxBxegedabagacad

# Set default editor
export EDITOR=vi

# Disable bash+less history
export HISTFILESIZE=0
export LESSHISTSIZE=0

# Ansible environment settings
export ANSIBLE_STDOUT_CALLBACK=yaml
export ANSIBLE_VAULT_PASSWORD_FILE="${HOME}/.ansible_vault"

# Prepend homebrew manpath, if applicable.
BREW_MANPATH=/usr/local/share/man
if [ -d "${BREW_MANPATH}" ]
then
  if [ ! -z "${MANPATH}" ]
  then
    export MANPATH="${BREW_MANPATH}:${MANPATH}"
  else
    export MANPATH="${BREW_MANPATH}"
  fi
fi

# Prepend homebrew binary paths, if applicable.
BREW_PACKAGES=/usr/local/opt
if [ -d "${BREW_PACKAGES}" ]
then
  for PACKAGE in ${BREW_PACKAGES}/*
  do
    for BINDIR in bin gnubin
    do
      if [ -d "${PACKAGE}/libexec/${BINDIR}" ]
      then
        export PATH="${PACKAGE}/libexec/${BINDIR}:${PATH}"
      fi
    done
  done
fi
