# .gitconfig

[color]
ui = auto

[core]
editor = vi
excludesfile = ~/.gitignore

[credential]
helper = osxkeychain

[fetch]
prune = true

[filter "lfs"]
clean = git-lfs clean -- %f
smudge = git-lfs smudge -- %f
process = git-lfs filter-process
required = true

[pull]
rebase = false

[push]
default = simple

[user]
email = tkimball83@users.noreply.github.com
name = Taylor Kimball

[includeIf "gitdir:~/Local/"]
path = ~/.gitconfig.local
